<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      CardFit is fully offline. The INTERNET permission is intentionally NOT declared.
      On-device ML Kit (document scanner, bundled text recognition) does not need it; its UI and
      models run in the separate Google Play services process. The Play-services libraries merge in
      INTERNET / ACCESS_NETWORK_STATE defensively, so we explicitly REMOVE them here (CLAUDE.md §2).
    -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />

    <uses-permission android:name="android.permission.CAMERA" />

    <!--
      Saving to public Downloads via MediaStore (API 29+) needs no permission. On API 24–28 we write
      to the public Downloads directory, which requires WRITE_EXTERNAL_STORAGE; capped at API 28 so
      it is never requested on modern devices.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CardFit">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CardFit">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
